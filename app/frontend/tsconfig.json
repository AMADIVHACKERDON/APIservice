{
    "compilerOptions": {
      "jsx": "react-jsx",
      "lib": ["DOM", "DOM.Iterable", "ESNext"],
      "moduleResolution": "bundler",
      "noEmit": true,
      "target": "ESNext",        
      "module": "ESNext",       
      "strict": true,             
      "esModuleInterop": true,    
      "skipLibCheck": true,      
    },
    "exclude": [
      "dist",
      "node_modules"
    ]  
  }
  