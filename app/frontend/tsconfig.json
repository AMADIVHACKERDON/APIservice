{
    "compilerOptions": {
      "jsx": "react-jsx",
      "lib": ["DOM", "DOM.Iterable", "ESNext"],
      "moduleResolution": "bundler",
      "noEmit": true,
      "target": "ESNext",         // Support modern JS features
      "module": "ESNext",         // Use modern import/export syntax
      "strict": true,             // Catch bugs early with strict type checking
      "esModuleInterop": true,    // Fixes "module has no default export" errors
      "skipLibCheck": true        // Speeds up builds by skipping type checks on node_modules
    }
  }
  